{
  "version": 2,
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/(chatbot-plus\\.js|chatbot-plus\\.css|privacy-policy\\.html)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
